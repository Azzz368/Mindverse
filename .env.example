# Leave this as mock for a key-free local canvas. Text and image providers can override it below.
AI_PROVIDER=mock

# 302.AI server-only configuration. Put real values in .env.local, never in NEXT_PUBLIC_ variables.
AI_302_API_KEY=
AI_302_API_ORIGIN=https://api.302.ai
AI_302_BASE_URL=https://api.302.ai/v1
AI_302_OPENAI_BASE_URL=https://api.302.ai/v1

# Model defaults. Text/script/storyboard/agent default to HKGAI MaaS.
AI_TEXT_PROVIDER=hkgai
AI_IMAGE_PROVIDER=302ai
AI_302_TEXT_MODEL=gpt-4o-mini
AGENT_LLM_PROVIDER=hkgai
AGENT_LLM_MODEL=gpt-4o
AI_302_STORYBOARD_MODEL=gpt-4o-mini
AI_302_IMAGE_MODEL=gpt-image-2
AI_302_VIDEO_MODEL=minimaxi-t2v-01
AI_302_TTS_MODEL=doubao
AI_302_TTS_VOICE=zh_male_beijingxiaoye_emo_v2_mars_bigtts

# QwenCloud / DashScope voice cloning + cloned voice TTS. Keep key server-only.
DASHSCOPE_API_KEY=
QWEN_DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
QWEN_COMPATIBLE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_OMNI_TTS_MODEL=qwen3.5-omni-plus
QWEN_OMNI_TTS_AUDIO_FORMAT=wav
# Leave false/blank unless the transcript is an exact word-for-word match for the reference audio.
QWEN_VOICE_CLONE_SEND_TRANSCRIPT=false

# Request behavior
AI_302_TIMEOUT_MS=120000
TEXT_LLM_MAX_RETRIES=1
AI_302_POLL_INTERVAL_MS=3000

# Codex + HyperFrames bridge. Point this at the Codex home that has your logged-in credentials.
# On Windows this is usually C:\Users\<you>\.codex. Set MINDVERSE_CODEX_REQUIRED=false
# only if a codex-hyperframes motion node may fall back to the baseline render.
MINDVERSE_CODEX_HOME=
# Codex edits can include multiple file/tool turns. Ten minutes is the default.
MINDVERSE_CODEX_TIMEOUT_MS=600000
# Optional: pin a model for website jobs; blank uses the logged-in Codex default.
MINDVERSE_CODEX_MODEL=
MINDVERSE_CODEX_REQUIRED=true
# API-key Codex providers can run exec in read-only mode unless this is enabled.
# Enable only for isolated HyperFrames job workers/containers.
MINDVERSE_CODEX_BYPASS_SANDBOX=false

# Agent full-web image search. Recommended: SerpAPI with Google or Bing Images.
# auto uses SerpAPI Google when SERPAPI_API_KEY exists, then Google CSE, then Wikimedia.
AGENT_IMAGE_SEARCH_PROVIDER=auto
SERPAPI_API_KEY=
AGENT_IMAGE_SEARCH_LANGUAGE=zh-cn
AGENT_IMAGE_SEARCH_COUNTRY=hk
AGENT_IMAGE_SEARCH_MARKET=zh-HK
# Optional for existing Google Custom Search JSON API customers.
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# HKGAI MaaS OpenAI-compatible text provider. Use for text/script/storyboard/agent only.
HKGAI_MAAS_API_KEY=
# Optional alias supported by the app:
HKGAI_API_KEY=
HKGAI_MAAS_BASE_URL=https://test-new-api.hkchat.app/v1
HKGAI_TEXT_MODEL=t2_hkgai-v3_fp8_1m_e7
HKGAI_STORYBOARD_MODEL=t2_hkgai-v3_fp8_1m_e7
HKGAI_AGENT_MODEL=t2_hkgai-v3_fp8_1m_e7
HKGAI_ENABLE_THINKING=false
HKGAI_THINKING_BUDGET=8192
HKGAI_MAAS_TIMEOUT_MS=120000

# Video provider: mock | 302ai | 302-sora2 | tokenstar | kling. Keep provider keys server-only.
AI_VIDEO_PROVIDER=mock

# Kling official image-to-video configuration. Replace ******** only in .env.local or Render.
KLING_API_KEY=********
KLING_API_ORIGIN=https://api-singapore.klingai.com
KLING_IMAGE_TO_VIDEO_PATH=/v1/videos/image2video
KLING_IMAGE_TO_VIDEO_POLL_PATH_TEMPLATE=/v1/videos/image2video/{taskId}
KLING_DEFAULT_DURATION=5
KLING_DEFAULT_RESOLUTION=720p
KLING_WATERMARK_ENABLED=false
KLING_POLL_INTERVAL_MS=5000

TOKENSTAR_API_KEY=
TOKENSTAR_API_ORIGIN=https://api.tokenstar.world
TOKENSTAR_VIDEO_MODEL=seedance-2.0-fast
TOKENSTAR_VIDEO_ASSET_MODEL=seedance-2.0-asset
TOKENSTAR_KLING_MODEL=kling-v3
TOKENSTAR_KLING_OMNI_MODEL=kling-v3-omni
TOKENSTAR_KLING_MODE=std
TOKENSTAR_KLING_ELEMENT_TAG_ID=o_105
TOKENSTAR_DEFAULT_RATIO=16:9
TOKENSTAR_DEFAULT_DURATION=8
TOKENSTAR_DEFAULT_RESOLUTION=720p
TOKENSTAR_GENERATE_AUDIO=true
TOKENSTAR_POLL_INTERVAL_MS=12000
TOKENSTAR_MAX_POLL_ATTEMPTS=80
TOKENSTAR_ASSET_POLL_INTERVAL_MS=1500
TOKENSTAR_ASSET_MAX_POLL_ATTEMPTS=20
TOKENSTAR_REQUEST_MAX_ATTEMPTS=2
TOKENSTAR_REQUEST_RETRY_MS=1500
